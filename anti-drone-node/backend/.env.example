# Serial port the ESP32 is connected to.
# Windows example: COM5
# macOS example:   /dev/tty.usbserial-0001
# Linux example:   /dev/ttyUSB0
SERIAL_PORT=COM5

# Must match Serial.begin(115200) in the firmware
BAUD_RATE=115200

# Backend HTTP/WebSocket port
PORT=4000

# Allowed origin for the React dashboard (Vite default dev server)
CORS_ORIGIN=http://localhost:5173
